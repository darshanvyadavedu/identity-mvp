# AWS credentials (backend + frontend)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Azure Face API (optional)
AZURE_FACE_ENDPOINT=https://eastus.api.cognitive.microsoft.com
AZURE_FACE_KEY=your_azure_key_here

# Backend
PORT=8080

# Frontend — Vite exposes VITE_ prefixed vars to the browser bundle
VITE_AWS_REGION=us-east-1
VITE_AWS_ACCESS_KEY_ID=your_access_key_here
VITE_AWS_SECRET_ACCESS_KEY=your_secret_key_here
